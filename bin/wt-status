#!/usr/bin/env bash
set -euo pipefail
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$LINK_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"
source "$SCRIPT_DIR/../lib/repo.sh"

usage() {
  cat <<'EOF2'
Usage:
  wt-status [--repo <path>] [--json] [-h|--help]
EOF2
}

REPO_ARG=""
JSON=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --repo)
      [[ $# -ge 2 && "${2:-}" != -* ]] || { echo "Error: --repo requires a value" >&2; exit 2; }
      REPO_ARG="$2"; shift 2 ;;
    --json) JSON=true; shift ;;
    --no-color) export NO_COLOR=1; shift ;;
    -*) echo "Error: unknown option '$1'" >&2; exit 2 ;;
    *) echo "Error: unexpected argument '$1'" >&2; exit 2 ;;
  esac
done

require_command git
REPO_ROOT="$(resolve_repo_root "$REPO_ARG")"
BARE_DIR="$(bare_repo_dir "$REPO_ROOT")"

mapfile -t ROWS < <(git -C "$BARE_DIR" worktree list --porcelain | awk '
  BEGIN { bare=0; detached=0; branch=""; head=""; path="" }
  /^worktree / { path=substr($0, length("worktree ")+1) }
  /^HEAD / { head=$2 }
  /^branch / { branch=$2; sub("refs/heads/","",branch) }
  /^bare$/ { bare=1 }
  /^detached$/ { detached=1 }
  /^$/ {
    if (!bare && path != "") {
      b = (detached ? "detached:" substr(head,1,8) : branch)
      printf "%s\t%s\n", path, b
    }
    bare=0; detached=0; branch=""; head=""; path=""
  }
  END {
    if (!bare && path != "") {
      b = (detached ? "detached:" substr(head,1,8) : branch)
      printf "%s\t%s\n", path, b
    }
  }
')

if [[ "$JSON" == true ]]; then
  printf '['
  first=true
  for row in "${ROWS[@]}"; do
    path="${row%%$'\t'*}"
    branch="${row#*$'\t'}"
    path="$(cd "$path" 2>/dev/null && pwd -P || echo "$path")"
    status_output="$(git -C "$path" status --porcelain 2>/dev/null || true)"
    dirty=false
    changes=0
    if [[ -n "$status_output" ]]; then
      dirty=true
      changes="$(printf '%s\n' "$status_output" | wc -l | tr -d ' ')"
    fi
    esc_path="${path//\\/\\\\}"; esc_path="${esc_path//\"/\\\"}"
    esc_branch="${branch//\\/\\\\}"; esc_branch="${esc_branch//\"/\\\"}"
    if [[ "$first" == true ]]; then first=false; else printf ','; fi
    printf '{"path":"%s","branch":"%s","dirty":%s,"changes":%s}' "$esc_path" "$esc_branch" "$dirty" "$changes"
  done
  printf ']\n'
  exit 0
fi

for row in "${ROWS[@]}"; do
  path="${row%%$'\t'*}"
  branch="${row#*$'\t'}"
  path="$(cd "$path" 2>/dev/null && pwd -P || echo "$path")"
  status_output="$(git -C "$path" status --short 2>/dev/null || true)"
  if [[ -z "$status_output" ]]; then
    state="clean"
  else
    state="dirty"
  fi
  printf "%s (%s): %s\n" "$path" "$branch" "$state"
done
