#!/usr/bin/env bash
set -euo pipefail
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$LINK_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"
source "$SCRIPT_DIR/../lib/repo.sh"

usage() {
  cat <<'EOF2'
Usage:
  wt-cleanup [--repo <path>] [--dry-run] [--yes]
EOF2
}

REPO_ARG=""
DRY_RUN=false
YES=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --repo)
      [[ $# -ge 2 && "${2:-}" != -* ]] || { echo "Error: --repo requires a value" >&2; exit 2; }
      REPO_ARG="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    --yes) YES=true; shift ;;
    --no-color) export NO_COLOR=1; shift ;;
    -*) echo "Error: unknown option '$1'" >&2; exit 2 ;;
    *) echo "Error: unexpected argument '$1'" >&2; exit 2 ;;
  esac
done

require_command git
REPO_ROOT="$(resolve_repo_root "$REPO_ARG")"
BARE_DIR="$(bare_repo_dir "$REPO_ROOT")"

mapfile -t CANDIDATES < <(
  git -C "$BARE_DIR" worktree list --porcelain | awk '
    BEGIN { bare=0; detached=0; branch=""; head=""; path="" }
    /^worktree / { path=substr($0, length("worktree ")+1) }
    /^HEAD / { head=$2 }
    /^branch / { branch=$2; sub("refs/heads/","",branch) }
    /^bare$/ { bare=1 }
    /^detached$/ { detached=1 }
    /^$/ {
      if (!bare && path != "" && !detached && branch != "main") {
        printf "%s\t%s\n", path, branch
      }
      bare=0; detached=0; branch=""; head=""; path=""
    }
    END {
      if (!bare && path != "" && !detached && branch != "main") {
        printf "%s\t%s\n", path, branch
      }
    }
  ' | while IFS=$'\t' read -r p b; do
    if git -C "$BARE_DIR" merge-base --is-ancestor "$b" main; then
      printf "%s\t%s\n" "$p" "$b"
    fi
  done
)

if [[ ${#CANDIDATES[@]} -eq 0 ]]; then
  log_info "No merged worktrees to clean up"
  exit 0
fi

if [[ "$DRY_RUN" == true ]]; then
  for row in "${CANDIDATES[@]}"; do
    log_info "Dry-run: would remove ${row%%$'\t'*} (${row#*$'\t'})"
  done
  exit 0
fi

confirm_or_exit "Remove ${#CANDIDATES[@]} merged worktree(s)?" "$YES"

SKIPPED=()
for row in "${CANDIDATES[@]}"; do
  p="${row%%$'\t'*}"
  b="${row#*$'\t'}"
  if [[ -n "$(git -C "$p" status --porcelain 2>/dev/null || true)" ]]; then
    log_warn "Skipping dirty worktree: $p ($b)"
    SKIPPED+=("$p ($b)")
    continue
  fi
  git -C "$BARE_DIR" worktree remove "$p"
  git -C "$BARE_DIR" branch -d "$b" >/dev/null || true
  log_success "Removed: $p ($b)"
done

if [[ ${#SKIPPED[@]} -gt 0 ]]; then
  log_warn "Skipped ${#SKIPPED[@]} dirty merged worktree(s)"
  exit 1
fi
